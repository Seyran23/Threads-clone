DATABASE_URL=postgresql://threads:threads_dev_password@localhost:5433/threads_clone

REDIS_URL=redis://localhost:6380

NEO4J_URI=bolt://localhost:7688
NEO4J_USER=neo4j
NEO4J_PASSWORD=threads_dev_password

# Access token: short-lived, sent on every request.
JWT_ACCESS_TOKEN_TTL=15m
# Refresh token: long-lived, rotated on every use. Family-based reuse
# detection revokes the whole family immediately if a used token is replayed.
JWT_REFRESH_TOKEN_TTL=30d

# RS256 keypairs (access + refresh). Generate with openssl, e.g.:
#   PRIVATE_KEY=$(openssl genpkey -algorithm RSA -pkeyopt rsa_keygen_bits:2048)
#   echo "$PRIVATE_KEY" | awk 'NR==1{printf "JWT_ACCESS_PRIVATE_KEY=\""} {printf "%s\\n", $0} END{print "\""}'
#   echo "$PRIVATE_KEY" | openssl rsa -pubout | awk 'NR==1{printf "JWT_ACCESS_PUBLIC_KEY=\""} {printf "%s\\n", $0} END{print "\""}'
# Repeat for JWT_REFRESH_PRIVATE_KEY / JWT_REFRESH_PUBLIC_KEY. Never commit real keys.
JWT_ACCESS_PRIVATE_KEY=
JWT_ACCESS_PUBLIC_KEY=
JWT_REFRESH_PRIVATE_KEY=
JWT_REFRESH_PUBLIC_KEY=
