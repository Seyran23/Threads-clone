DATABASE_URL=postgresql://threads:threads_dev_password@localhost:5433/threads_clone

# Access token: short-lived, sent on every request.
JWT_ACCESS_TOKEN_TTL=15m
# Refresh token: long-lived, rotated on every use. Family-based reuse
# detection revokes the whole family immediately if a used token is replayed.
JWT_REFRESH_TOKEN_TTL=30d
