# Postgres
POSTGRES_USER=threads
POSTGRES_PASSWORD=threads_dev_password
POSTGRES_DB=threads_clone
DATABASE_URL=postgresql://threads:threads_dev_password@localhost:5433/threads_clone

# Redis
REDIS_URL=redis://localhost:6380

# Neo4j
NEO4J_USER=neo4j
NEO4J_PASSWORD=threads_dev_password
NEO4J_URI=bolt://localhost:7688

# Mailhog (local SMTP catcher)
SMTP_HOST=localhost
SMTP_PORT=1026

# MinIO (S3-compatible, local dev only). Must match the defaults baked into
# docker-compose.yml's minio service unless this file is actually copied to
# a root .env to override them.
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin_dev
S3_ENDPOINT=http://localhost:9002
S3_ACCESS_KEY=minioadmin
S3_ACCESS_SECRET=minioadmin_dev
S3_BUCKET=threads-clone-media
